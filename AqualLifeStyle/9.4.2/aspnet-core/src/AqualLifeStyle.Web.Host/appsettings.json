{
  "ConnectionStrings": {
    "Default": "<set-via-env:ConnectionStrings__Default>"
  },
  "App": {
    "ServerRootAddress": "https://localhost:44311/",
    "ClientRootAddress": "http://localhost:4200/",
    "CorsOrigins": "http://localhost:4200,http://localhost:8080,http://localhost:8081,http://localhost:3000"
  },
  "Authentication": {
    "JwtBearer": {
      "IsEnabled": "true",
      "SecurityKey": "<set-via-user-secret-or-env:JwtBearer__SecurityKey>",
      "Issuer": "AqualLifeStyle",
      "Audience": "AqualLifeStyle"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "https://localhost:44311/"
      }
    }
  },
  "Swagger": {
    "ShowSummaries": false
  }
}
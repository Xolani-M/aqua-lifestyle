# Example .env file - DO NOT commit real secrets
# Copy to .env and fill with real values for local testing only

# Connection string consumed by the app
ConnectionStrings__Default="Host=localhost;Port=5432;Database=AqualLifeStyleDemo;Username=postgres;Password=change_me;Ssl Mode=Prefer;"

# JWT settings
JwtBearer__SecurityKey="ChangeThisToAStrongSecret"
JwtBearer__Issuer="AqualLifeStyle"
JwtBearer__Audience="AqualLifeStyle"

# Optional: set environment
# ASPNETCORE_ENVIRONMENT=Development
